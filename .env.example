# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Search API Keys ────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=BSA...
EXA_API_KEY=...

# ── Neo4j ──────────────────────────────────────────────────────────────────────
# Set NEO4J_ENABLED=false to skip graph persistence entirely (no Neo4j required)
NEO4J_ENABLED=true

# Option A: Neo4j Desktop (local) — default URI
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=strongpassword123

# Option B: Neo4j AuraDB (cloud free tier) — replace URI with your instance URL
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<aura-generated-password>

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=deep-research-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Agent settings ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
REPORTS_DIR=reports
LOGS_DIR=logs
MAX_SEARCH_RESULTS_PER_QUERY=10
SEARCH_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.1
MAX_CONCURRENT_SEARCHES=5
